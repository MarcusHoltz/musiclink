# copy to .env and edit before running docker compose up

# ── Security ──────────────────────────────────────────────────────────────────
# Web terminal login  format: username:password
# Change this  anyone who can reach WEB_PORT can log in
TTYD_CREDENTIAL=admin:changeme

# ── Port ──────────────────────────────────────────────────────────────────────
# HTTPS port for the web UI  change if already in use
WEB_PORT=7681

# ── Paths ─────────────────────────────────────────────────────────────────────
# These must be real filesystem paths visible on your host
# MusicLink writes symlinks using these strings  they must resolve outside Docker

# Where the file browser opens  set to the parent of all your source shares
# so they appear as subfolders  examples by platform:
#   Unraid:         /mnt/user
#   TrueNAS:        /mnt/tank
#   OpenMediaVault: /srv/dev-disk-by-uuid-.../
#   Local disk:     /home/username/Music
SOURCE_DIR=/mnt/user

# Where your curated symlink library is created  must be an existing directory
#   Unraid:         /mnt/user/CuratedMusic
#   TrueNAS:        /mnt/tank/CuratedMusic
#   Local disk:     /home/username/CuratedLibrary
TARGET_DIR=/mnt/user/CuratedMusic

# ── Volume mappings (edit docker-compose.yml not here) ────────────────────────
# Your source shares and output share are defined as volumes in docker-compose.yml
# Each share must follow this rule:
#
#   host path = container path   or symlinks will be broken outside Docker
#
#   correct:  /mnt/user/Music:/mnt/user/Music:ro
#   wrong:    /mnt/user/Music:/music:ro
#
# Open docker-compose.yml and add one line per source share under volumes
